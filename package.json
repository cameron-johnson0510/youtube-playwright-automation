{
  "name": "youtube-automation",
  "version": "1.0.0",
  "description": "Playwright TypeScript test automation framework for YouTube",
  "scripts": {
    "test": "playwright test",
    "test:happy-path": "playwright test tests/happy-path/",
    "test:error-states": "playwright test tests/error-states/",
    "test:api": "playwright test tests/api/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "allure-js-commons": "^3.0.0",
    "allure-playwright": "^3.6.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "allure": "^3.3.1"
  }
}
